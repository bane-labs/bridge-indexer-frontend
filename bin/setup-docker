#!/bin/bash

set -euo pipefail

echo "\nSetting up Docker-based dev environment..."

if [ -f ".env.example" ] && [ ! -f ".env" ]; then
echo "Creating .env from .env.example..."
cp .env.example .env
fi

echo "\nBuilding and starting containers..."
docker compose -f docker-compose.dev.yml up --build -d

echo "\nInstalling node_modules on host for VS Code..."
pnpm install

echo "\nSetup complete! Starting containers in foreground..."
docker compose -f docker-compose.dev.yml up
