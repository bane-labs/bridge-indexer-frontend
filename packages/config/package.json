{
  "name": "@atlas/config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared configuration for linting, formatting, and TypeScript",
  "exports": {
    "./eslint": "./eslint.config.mjs",
    "./typescript": "./tsconfig.base.json",
    "./typescript/nextjs": "./tsconfig.nextjs.json",
    "./typescript/react-library": "./tsconfig.react-library.json",
    "./prettier": "./.prettierrc.json",
    "./jest": "./jest.config.js"
  },
  "files": [
    "eslint.config.mjs",
    "tsconfig.*.json",
    ".prettierrc.json",
    "jest.config.js"
