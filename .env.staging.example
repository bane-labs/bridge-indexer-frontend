# ==========================================
# Atlas Staging Environment Variables
# ==========================================
# Copy this file to .env.staging and fill in your values
# Never commit .env.staging to version control

# ==========================================
# Node Environment
# ==========================================
NODE_ENV=production

# ==========================================
# Server-Only Variables
# ==========================================
# Database connection URL
# Example: postgresql://user:password@db:5432/atlas_staging
DATABASE_URL=postgresql://user:password@postgres:5432/atlas_staging

# ==========================================
# Client-Side Variables
# ==========================================
# Base API URL for client-side requests
NEXT_PUBLIC_API_URL=https://banelabs-bridge-indexer-backend.app.mf.axlabs.net/

# Environment identifier (affects Web Vitals sampling)
NEXT_PUBLIC_APP_ENV=staging

# Build ID for version tracking (optional, injected by CI)
NEXT_PUBLIC_BUILD_ID=

# ==========================================
# Web Vitals Configuration
# ==========================================
# Enable/disable Web Vitals reporting
# Default: enabled in staging
NEXT_PUBLIC_WEB_VITALS_ENABLED=true

# Sample rate (0-1). 0.25 = 25% of sessions
# Default: 0.25 in staging (higher than production for more data)
NEXT_PUBLIC_WEB_VITALS_SAMPLE_RATE=0.25

# Debug logging (useful in staging)
# NEXT_PUBLIC_WEB_VITALS_DEBUG=true

# ==========================================
# Docker Service Variables (Optional)
# ==========================================
# Only needed if using database/cache profiles

# Database credentials (for postgres service)
DB_USER=atlas
DB_PASSWORD=your_staging_db_password

# Redis password (for redis service)
REDIS_PASSWORD=your_staging_redis_password
