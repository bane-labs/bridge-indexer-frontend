# Add Docker path and setup NVM environment
export PATH="$PATH:/usr/local/bin:/opt/homebrew/bin"

# Load NVM if available and align with project Node version
export NVM_DIR="$HOME/.nvm"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  . "$NVM_DIR/nvm.sh"
fi

# Try to use correct Node version if NVM is available
if command -v nvm >/dev/null 2>&1; then
  if ! nvm use >/dev/null 2>&1; then
    echo "⚠️  Warning: Node v22 not installed via NVM. Run 'nvm install' to use the project's Node version."
    echo "ℹ️  Continuing with current Node version..."
  fi
fi

# Enable Corepack to ensure correct pnpm version from package.json
if command -v corepack >/dev/null 2>&1; then
  corepack enable
else
  echo "⚠️  Warning: Corepack not available. Attempting to use system pnpm..."
fi

pnpm typecheck && pnpm test
