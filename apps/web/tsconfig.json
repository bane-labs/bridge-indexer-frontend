{
  "extends": "../../packages/config/tsconfig.nextjs.json",
  "compilerOptions": {
    "baseUrl": "./",
    "skipLibCheck": true,
    "types": ["jest", "@testing-library/jest-dom"],
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@/*": ["./src/*", "../../packages/ui/src/*"],
      "@/components/*": ["./src/components/*"],
      "@/lib/*": ["./src/lib/*", "../../packages/ui/src/lib/*"],
      "@/hooks/*": ["./src/hooks/*"]
    },
    "noEmit": true,
    "allowArbitraryExtensions": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    "e2e/**/*.ts",
    "scripts/**/*.ts",
    "*.config.ts",
    "instrumentation.ts",
    "instrumentation-client.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "src/test"]
}
