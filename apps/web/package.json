{
  "name": "@atlas/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"src/**/*.{ts,tsx,js,jsx}\"",
    "format:write": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "typecheck": "next typegen && tsc --noEmit",
    "validate:env": "tsx scripts/validate-env.ts",
    "api:gen": "openapi-typescript ../../openapi/openapi.json -o src/lib/api/contracts/schema.ts --empty-objects-unknown",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "clean": "rm -rf .next .turbo node_modules",
    "perf:lhci": "lhci autorun --config=../../lighthouserc.json",
    "perf:analyze": "ANALYZE=true pnpm build"
  },
  "dependencies": {
    "@atlas/ui": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@next/third-parties": "^16.2.4",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.32.1",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "5.62.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "^0.561.0",
    "next": "16.0.10",
    "next-themes": "0.4.4",
    "pino": "^10.1.0",
    "posthog-js": "^1.310.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.68.0",
    "server-only": "^0.0.1",
    "sonner": "1.7.4",
    "tailwind-merge": "2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "web-vitals": "^4.2.4",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@atlas/config": "workspace:*",
    "@lhci/cli": "^0.14.0",
    "@next/bundle-analyzer": "^15.1.3",
    "@playwright/test": "1.49.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/jest": "29.5.14",
    "@types/node": "22.10.2",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.20",
    "eslint": "9.17.0",
    "fishery": "^2.4.0",
    "identity-obj-proxy": "3.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "msw": "^1.3.3",
    "openapi-typescript": "^7.10.1",
    "postcss": "8.5.6",
    "prettier": "3.4.2",
    "tailwindcss": "4.1.18",
    "ts-jest": "29.2.5",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
