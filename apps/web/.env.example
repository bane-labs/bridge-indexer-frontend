# ==========================================
# Atlas Environment Variables
# ==========================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control
#
# Validation: Run `pnpm validate:env` to check your configuration
# Documentation: docs/ATLAS_CONTEXT.md

# ==========================================
# Node Environment
# ==========================================
# Options: development | test | production
NODE_ENV=development

# ==========================================
# Server-Only Variables (Never exposed to client)
# ==========================================
# These are only accessible in API routes, server components, and middleware
# Validated by: apps/web/src/schemas/env/server-runtime-config.ts

# Logging level for server-side logs
# Options: debug | info | warn | error
LOG_LEVEL=info

# Server-side API base URL (optional)
# Used when server needs to make API calls to itself
# API_BASE_URL=http://localhost:3001/api

# Bridge indexer upstream (optional). With NEXT_PUBLIC_API_URL=/api/indexer, Next.js
# rewrites /api/indexer/* to this URL so local dev avoids CORS (preflight fails if the
# upstream does not answer OPTIONS with Allow-Headers for x-request-id, etc.).
# INDEXER_API_UPSTREAM=https://your-indexer-host.example.com

# Database connection URL
# Example: postgresql://user:password@localhost:5432/atlas_dev
DATABASE_URL=postgresql://user:password@localhost:5432/atlas

# ==========================================
# Sentry - Error Monitoring (Server-Side)
# ==========================================
# Optional: When not set, Sentry is gracefully disabled
# Get your DSN from: https://sentry.io/settings/[org]/projects/[project]/keys/

# Sentry DSN for server-side error tracking
# SENTRY_DSN=https://YOUR_KEY@oYOUR_ORG.ingest.sentry.io/YOUR_PROJECT

# Sentry environment (defaults to NODE_ENV if not set)
# Options: production | staging | development
# SENTRY_ENVIRONMENT=development

# Sentry release identifier (recommended for production)
# Use git SHA or semantic version
# SENTRY_RELEASE=my-app@1.0.0

# Enable Sentry in development (disabled by default)
# SENTRY_ENABLE_IN_DEV=true

# ==========================================
# Sentry - Sourcemap Upload (CI/CD Only)
# ==========================================
# Only required when uploading sourcemaps in CI/CD builds
# Builds work without these - they just disable sourcemap upload

# Sentry auth token (create at: Sentry → Settings → Auth Tokens)
# Required permissions: project:releases, project:write
# SENTRY_AUTH_TOKEN=your_auth_token_here

# Sentry organization slug
# SENTRY_ORG=your-org-slug

# Sentry project slug
# SENTRY_PROJECT=atlas-web

# ==========================================
# Client-Side Variables (Safe to expose in browser)
# ==========================================
# All variables starting with NEXT_PUBLIC_ are bundled into client code
# Validated by: apps/web/src/schemas/env/public-runtime-config.ts

# Base API URL for client-side requests
# Production may call the indexer directly if CORS allows your origin and OPTIONS (preflight).
# Local dev: use same-origin proxy to avoid CORS — set NEXT_PUBLIC_API_URL=/api/indexer and
# INDEXER_API_UPSTREAM=https://your-indexer-host (see server-only vars above).
# Development (direct): http://localhost:3001
# Production (direct): https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Application environment identifier (optional)
# Options: development | staging | production
# NEXT_PUBLIC_APP_ENV=development

# Build ID for version tracking (optional)
# Usually set automatically in CI/CD
# NEXT_PUBLIC_BUILD_ID=

# ==========================================
# Web Vitals - Performance Monitoring (Optional)
# ==========================================

# Enable/disable Web Vitals reporting
# NEXT_PUBLIC_WEB_VITALS_ENABLED=true

# Sample rate for Web Vitals (0-1)
# NEXT_PUBLIC_WEB_VITALS_SAMPLE_RATE=0.05

# Custom endpoint for Web Vitals data
# NEXT_PUBLIC_WEB_VITALS_ENDPOINT=/api/telemetry/web-vitals

# Debug mode for Web Vitals
# NEXT_PUBLIC_WEB_VITALS_DEBUG=false

# ==========================================
# Sentry - Error Monitoring (Client-Side)
# ==========================================
# Optional: When not set, Sentry is gracefully disabled
# Note: These are PUBLIC and will be visible in browser bundles

# Sentry DSN for client-side error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oYOUR_ORG.ingest.sentry.io/YOUR_PROJECT

# Sentry environment (should match server-side SENTRY_ENVIRONMENT)
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Sentry release identifier (should match server-side SENTRY_RELEASE)
# NEXT_PUBLIC_SENTRY_RELEASE=my-app@1.0.0

# Enable Sentry in development (disabled by default)
# NEXT_PUBLIC_SENTRY_ENABLE_IN_DEV=true

# ==========================================
# Analytics (Optional)
# ==========================================

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com → Admin → Data Streams
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog API key
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxx

# PostHog API host (defaults to https://us.i.posthog.com)
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Enable analytics debug mode
# NEXT_PUBLIC_ANALYTICS_DEBUG=false

# ==========================================
# Optional: Skip Environment Validation
# ==========================================
# Set to 'true' to skip validation (not recommended for production)
# SKIP_ENV_VALIDATION=false

# ==========================================
# Security Configuration
# ==========================================
# See docs/SECURITY.md for detailed documentation

# Enable HSTS (Strict-Transport-Security)
# Only enable in production when HTTPS is guaranteed
# WARNING: This commits your domain to HTTPS - cannot easily undo
# ENABLE_HSTS=true

# ==========================================
# OAuth / Authentication
# ==========================================
# Required for OAuth authentication (Google, etc.)
# See docs/OAUTH.md for detailed setup instructions

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth Client Secret
# Keep this secret secure - never commit real values
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Session encryption secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
AUTH_SESSION_SECRET=your-32-character-secret-key-here-replace-me

# Session TTL in seconds (default: 604800 = 7 days)
# AUTH_SESSION_TTL_SECONDS=604800

# Application URL (used for OAuth callbacks)
# Required for OAuth redirect URIs
NEXT_PUBLIC_APP_URL=http://localhost:3000
