# ==========================================
# CI/CD Environment Variables Reference
# ==========================================
# This file documents environment variables needed in CI/CD pipelines
# Add these as secrets/variables in your CI/CD platform:
# - GitHub Actions: Repository Settings > Secrets and Variables > Actions
# - GitLab CI: Settings > CI/CD > Variables
# - CircleCI: Project Settings > Environment Variables

# ==========================================
# Required for Build & Test
# ==========================================

# Node environment (typically 'production' or 'test' in CI)
NODE_ENV=production

# Database connection for tests/migrations
# Use a test database URL or mock connection
# Example: postgresql://postgres:postgres@localhost:5432/atlas_test
DATABASE_URL=postgresql://user:password@localhost:5432/atlas_ci

# Public API URL for E2E tests and builds
# Use staging or test API endpoint
NEXT_PUBLIC_API_URL=https://banelabs-bridge-indexer-backend.app.mf.axlabs.net/

# ==========================================
# Optional CI Variables
# ==========================================

# Skip validation if using dynamic environment injection
# Generally should be 'false' to catch issues early
SKIP_ENV_VALIDATION=false

# ==========================================
# GitHub Actions Example Configuration
# ==========================================
# Add these to .github/workflows/ci.yml:
#
# jobs:
#   build:
#     steps:
#       - name: Build
#         run: pnpm build
#         env:
#           NODE_ENV: production
#           DATABASE_URL: ${{ secrets.DATABASE_URL }}
#           NEXT_PUBLIC_API_URL: ${{ vars.NEXT_PUBLIC_API_URL }}
