# ==========================================
# Atlas Production Environment Variables
# ==========================================
# Copy this file to .env.production and fill in your values
# Never commit .env.production to version control

# ==========================================
# Node Environment
# ==========================================
NODE_ENV=production

# ==========================================
# Server-Only Variables
# ==========================================
# Database connection URL
# Example: postgresql://user:password@db:5432/atlas
DATABASE_URL=postgresql://user:password@postgres:5432/atlas

# ==========================================
# Client-Side Variables
# ==========================================
# Base API URL for client-side requests
NEXT_PUBLIC_API_URL=https://banelabs-bridge-indexer-backend.app.mf.axlabs.net/

# Environment identifier (affects Web Vitals sampling)
NEXT_PUBLIC_APP_ENV=production

# Build ID for version tracking (optional, injected by CI)
NEXT_PUBLIC_BUILD_ID=

# ==========================================
# Web Vitals Configuration
# ==========================================
# Enable/disable Web Vitals reporting
# Default: enabled in production
NEXT_PUBLIC_WEB_VITALS_ENABLED=true

# Sample rate (0-1). 0.05 = 5% of sessions
# Default: 0.05 in production
NEXT_PUBLIC_WEB_VITALS_SAMPLE_RATE=0.05

# API endpoint override (optional)
# Default: /api/telemetry/web-vitals
# NEXT_PUBLIC_WEB_VITALS_ENDPOINT=/api/telemetry/web-vitals

# Debug logging (not recommended in production)
# NEXT_PUBLIC_WEB_VITALS_DEBUG=false

# ==========================================
# Docker Service Variables (Optional)
# ==========================================
# Only needed if using database/cache profiles

# Database credentials (for postgres service)
DB_USER=atlas
DB_PASSWORD=your_production_db_password

# Redis password (for redis service)
REDIS_PASSWORD=your_production_redis_password
