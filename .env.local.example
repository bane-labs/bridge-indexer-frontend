# ==========================================
# Atlas Local Development Environment
# ==========================================
# Copy this to .env.local for local development
# This file is gitignored by default

# ==========================================
# Node Environment
# ==========================================
NODE_ENV=development

# ==========================================
# Server-Only Variables
# ==========================================
# Database connection URL (optional for local dev)
# DATABASE_URL=postgresql://user:password@localhost:5432/atlas_dev

# ==========================================
# Client-Side Variables
# ==========================================
# Base API URL for client-side requests
NEXT_PUBLIC_API_URL=https://banelabs-bridge-indexer-backend.app.mf.axlabs.net/

# Environment identifier
NEXT_PUBLIC_APP_ENV=development

# ==========================================
# Web Vitals Configuration (Testing)
# ==========================================
# Enable Web Vitals in development (disabled by default)
NEXT_PUBLIC_WEB_VITALS_ENABLED=true

# Full sampling for local testing
NEXT_PUBLIC_WEB_VITALS_SAMPLE_RATE=1

# Enable debug logging
NEXT_PUBLIC_WEB_VITALS_DEBUG=true
